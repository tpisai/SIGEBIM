              <Font name="Segoe Print" size="14" style="0"/>
            </Property>
            <Property name="text" type="java.lang.String" value="&lt;html&gt; 1. &lt;b&gt;Respaldo:&lt;/b&gt; Haga clic en &lt;b&gt;[EXAMINAR]&lt;/b&gt; y elija la carpeta de destino para sus backups.&lt;br&gt; 2. &lt;b&gt;Multas:&lt;/b&gt; Ingrese el monto por d&#xed;a de retraso en el campo &apos;Monto de Multa&apos;.&lt;br&gt; 3. &lt;b&gt;Plazo:&lt;/b&gt; Ingrese el l&#xed;mite de d&#xed;as permitidos antes de multar.&lt;br&gt; 4. &lt;b&gt;Guardar:&lt;/b&gt; Presione &lt;b&gt;[GUARDAR CONFIGURACI&#xd3;N]&lt;/b&gt;.&lt;br&gt;&lt;br&gt; &lt;i&gt;Nota: Estos cambios son globales y afectan el c&#xe1;lculo autom&#xe1;tico de multas.&lt;/i&gt; &lt;/html&gt;"/>
          </Properties>
        </Component>
