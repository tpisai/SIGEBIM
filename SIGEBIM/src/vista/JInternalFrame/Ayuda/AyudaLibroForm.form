            <Property name="text" type="java.lang.String" value="C&#xd3;MO REGISTRAR UN LIBRO?"/>
          </Properties>
        </Component>
        <Component class="javax.swing.JLabel" name="jLabel29">
          <Properties>
            <Property name="background" type="java.awt.Color" editor="org.netbeans.beaninfo.editors.ColorEditor">
              <Color blue="33" green="6f" red="96" type="rgb"/>
            </Property>
            <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
              <Font name="Segoe Print" size="14" style="0"/>
            </Property>
            <Property name="text" type="java.lang.String" value="&lt;html&gt; &lt;b&gt;1. REGISTRO DE NUEVO LIBRO:&lt;/b&gt;&lt;br&gt; - &lt;b&gt;ISBN:&lt;/b&gt; Ingrese el c&#xf3;digo de barras &#xfa;nico del libro (13 d&#xed;gitos).&lt;br&gt; - &lt;b&gt;T&#xed;tulo y Autor:&lt;/b&gt; Escriba el nombre del libro y qui&#xe9;n lo escribi&#xf3;.&lt;br&gt; - &lt;b&gt;A&#xf1;o:&lt;/b&gt; Registre el a&#xf1;o en que se public&#xf3;.&lt;br&gt; - &lt;b&gt;Formato y URL:&lt;/b&gt; Indique si el libro es f&#xed;sico o digital. Si es digital, agregue el enlace en el campo URL.&lt;br&gt; - &lt;b&gt;Stock:&lt;/b&gt; Indique cu&#xe1;ntos ejemplares est&#xe1;n ingresando. El &lt;b&gt;Estado&lt;/b&gt; del libro se asignar&#xe1; autom&#xe1;ticamente seg&#xfa;n este valor.&lt;br&gt; - &lt;b&gt;Guardar:&lt;/b&gt; Presione el bot&#xf3;n &lt;b&gt;[GUARDAR]&lt;/b&gt; para registrar el libro.&lt;br&gt;&lt;br&gt;  &lt;b&gt;2. C&#xd3;MO BUSCAR UN LIBRO:&lt;/b&gt;&lt;br&gt; - &lt;b&gt;B&#xfa;squeda por Autor:&lt;/b&gt; Use la primera barra de b&#xfa;squeda superior escribiendo el nombre del autor para filtrar sus obras.&lt;br&gt; - &lt;b&gt;B&#xfa;squeda General:&lt;/b&gt; Use la segunda barra de b&#xfa;squeda para localizar libros r&#xe1;pidamente por su Categor&#xed;a.&lt;br&gt; - Presione &lt;b&gt;[BUSCAR]&lt;/b&gt;. La tabla inferior mostrar&#xe1; &#xfa;nicamente los libros que coincidan.&lt;br&gt; - Para volver a ver toda la lista, solo debe presionar &lt;b&gt;[MOSTRAR TODO]&lt;/b&gt; &lt;/html&gt;"/>
          </Properties>
        </Component>
      </SubComponents>
