            <Property name="text" type="java.lang.String" value="C&#xd3;MO REGISTRAR UN USUARIO?"/>
          </Properties>
        </Component>
        <Component class="javax.swing.JLabel" name="jLabel29">
          <Properties>
            <Property name="background" type="java.awt.Color" editor="org.netbeans.beaninfo.editors.ColorEditor">
              <Color blue="33" green="6f" red="96" type="rgb"/>
            </Property>
            <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
              <Font name="Segoe Print" size="14" style="0"/>
            </Property>
            <Property name="text" type="java.lang.String" value="&lt;html&gt; &lt;b&gt;1. REGISTRO AUTOM&#xc1;TICO:&lt;/b&gt;&lt;br&gt; - &lt;b&gt;DNI:&lt;/b&gt; Ingrese el n&#xfa;mero de DNI (8 d&#xed;gitos) del lector.&lt;br&gt; - Presione el bot&#xf3;n &lt;b&gt;[VALIDAR DNI]&lt;/b&gt;. El sistema buscar&#xe1; a la persona y llenar&#xe1; sus Nombres y Apellidos autom&#xe1;ticamente.&lt;br&gt; - &lt;b&gt;Credenciales y Rol:&lt;/b&gt; Asigne un Username (nombre de usuario), una Password (contrase&#xf1;a de acceso) y seleccione el Rol de Usuario correspondiente.&lt;br&gt; - &lt;b&gt;Contacto:&lt;/b&gt; Ingrese un Correo Electr&#xf3;nico y un Tel&#xe9;fono v&#xe1;lidos para notificaciones.&lt;br&gt; - Presione &lt;b&gt;[REGISTRAR]&lt;/b&gt; para habilitar al lector en el sistema.&lt;br&gt;&lt;br&gt;  &lt;b&gt;2. B&#xda;SQUEDA Y EDICI&#xd3;N:&lt;/b&gt;&lt;br&gt; - Escriba el DNI en la barra de b&#xfa;squeda para encontrar r&#xe1;pidamente a un lector.&lt;br&gt; - Seleccione al usuario en la tabla para actualizar sus datos de contacto, modificar su Username / Password, o cambiar su Rol de Usuario si es necesario. &lt;/html&gt;"/>
          </Properties>
        </Component>
      </SubComponents>
