              <Color blue="33" green="33" red="ff" type="rgb"/>
            </Property>
            <Property name="text" type="java.lang.String" value="C&#xd3;MO REALIZAR UN PR&#xc9;STAMO?"/>
          </Properties>
        </Component>
        <Component class="javax.swing.JLabel" name="jLabel29">
          <Properties>
            <Property name="background" type="java.awt.Color" editor="org.netbeans.beaninfo.editors.ColorEditor">
              <Color blue="33" green="6f" red="96" type="rgb"/>
            </Property>
            <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
              <Font name="Segoe Print" size="14" style="0"/>
            </Property>
            <Property name="text" type="java.lang.String" value="&lt;html&gt;1. C&#xd3;MO PRESTAR UN LIBRO:&lt;/b&gt;&lt;br&gt; - &lt;b&gt;Lector:&lt;/b&gt; Ingrese el DNI del usuario. El sistema verificar&#xe1; si no tiene multas pendientes.&lt;br&gt; - &lt;b&gt;Libro:&lt;/b&gt; Ingrese el ISBN del libro que desea llevar. El sistema verificar&#xe1; que haya Stock disponible.&lt;br&gt; - &lt;b&gt;Fecha de Devoluci&#xf3;n:&lt;/b&gt; Seleccione en el calendario qu&#xe9; d&#xed;a debe devolver el libro.&lt;br&gt; - Presione &lt;b&gt;[CONFIRMAR PR&#xc9;STAMO]&lt;/b&gt;. El stock del libro se reducir&#xe1; autom&#xe1;ticamente.&lt;br&gt;&lt;br&gt; &lt;b&gt;2. C&#xd3;MO REGISTRAR UNA DEVOLUCI&#xd3;N:&lt;/b&gt;&lt;br&gt; - Busque el pr&#xe9;stamo activo usando el DNI del lector.&lt;br&gt; - Seleccione el registro y presione &lt;b&gt;[PROCESAR DEVOLUCI&#xd3;N]&lt;/b&gt;.&lt;br&gt; - Si el lector se excedi&#xf3; de la fecha acordada, el sistema calcular&#xe1; autom&#xe1;ticamente la multa a pagar. &lt;/html&gt;"/>
          </Properties>
        </Component>
      </SubComponents>
