              <Font name="Segoe Print" size="14" style="0"/>
            </Property>
            <Property name="text" type="java.lang.String" value="&lt;html&gt; 1. &lt;b&gt;B&#xfa;squeda:&lt;/b&gt; Ingrese DNI e ISBN, luego presione &lt;b&gt;[BUSCAR]&lt;/b&gt;.&lt;br&gt; 2. &lt;b&gt;Verificaci&#xf3;n:&lt;/b&gt; Aseg&#xfa;rese que el estado sea &apos;Disponible&apos;.&lt;br&gt; 3. &lt;b&gt;Confirmaci&#xf3;n:&lt;/b&gt; Defina la fecha y presione &lt;b&gt;[CONFIRMAR PR&#xc9;STAMO]&lt;/b&gt;.&lt;br&gt; 4. &lt;b&gt;Estado:&lt;/b&gt; El libro pasar&#xe1; autom&#xe1;ticamente a &apos;No Disponible&apos;.&lt;br&gt;&lt;br&gt; &lt;i&gt;Nota: Si el ejemplar no est&#xe1; disponible, el sistema bloquear&#xe1; la operaci&#xf3;n.&lt;/i&gt; &lt;/html&gt;"/>
          </Properties>
        </Component>
